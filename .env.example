# ==============================================================================
# TenantShield - Environment Configuration Template
# ==============================================================================

# 1. BRANDING & MAIN SETTINGS
NEXT_PUBLIC_APP_NAME=TenantShield
NEXT_PUBLIC_SITE_URL=https://tenantshield-saas.vercel.app

# 2. SUPABASE CONNECTION CONFIG
# Get these values from your Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# 3. NEXTAUTH / JWT ENCRYPTION SECRET
# Generate a secure 32-character random string (e.g. openssl rand -base64 32)
NEXTAUTH_SECRET=your-nextauth-secret-32-chars

# 4. EMAIL INTEGRATION (RESEND)
# Required for sending transactional emails (invitations, alerts)
RESEND_API_KEY=re_your_resend_api_key

# 5. SOAR ACTIVE DEFENSE (TELEGRAM NOTIFIER)
# Create a bot via @BotFather and get the token. Chat ID can be resolved via @userinfobot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# 6. EDGE THREAT LIMITER (REDIS)
# Required for Edge-native rate limiting and threat blocking.
# Get serverless Redis connection details from Upstash Console.
REDIS_URL=redis://default:password@your-redis-host:6379

# 7. VERCEL DEPLOYMENT CONFIG (FOR DYNAMIC CUSTOM DOMAINS)
# Required only if you support buyer custom domain mapping.
VERCEL_PROJECT_ID=your-project-id
VERCEL_AUTH_TOKEN=your-vercel-auth-token
VERCEL_TEAM_ID=your-team-id

# NOTE ON FIREBASE FCM:
# Push Notification integration via Firebase FCM is disabled in this build to minimize
# third-party dependencies and setup friction. No Firebase config is required.