# SUPABASE CONNECTION CONFIG
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# NEXTAUTH OR JWT SECRET
NEXTAUTH_SECRET=your-nextauth-secret-32-chars

# ACTIVE DEFENSE TELEGRAM NOTIFIER
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# REDIS LIMITER (OPTIONAL FOR RATE LIMITING)
REDIS_URL=redis://default:password@your-redis-host:6379

# VERCEL DEPLOYMENT CONFIG (FOR DOMAIN ALIASING)
VERCEL_PROJECT_ID=your-project-id
VERCEL_AUTH_TOKEN=your-vercel-auth-token
VERCEL_TEAM_ID=your-team-id